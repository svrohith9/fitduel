# Supabase — copy to .env.local and fill in from your project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# New "publishable" key (recommended — starts with sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# OR the legacy anon key (starts with eyJ...) — either works.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
